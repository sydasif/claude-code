{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:8080/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "sk-1234",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "gemini-3.1-flash-lite",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "gemma-4-31b-it",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "gemma-4-26b-a4b-it"
  },
  "permissions": {
    "allow": [
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/zulu/.claude/hooks/block-websearch.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/zulu/.claude/hooks/ruff-after-edit.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash ~/.claude/hooks/statusline.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "repomix-mcp@repomix": true
  },
  "extraKnownMarketplaces": {
    "repomix": {
      "source": {
        "source": "github",
        "repo": "yamadashy/repomix"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "theme": "dark"
}
