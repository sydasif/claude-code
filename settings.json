{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "mcp__ddg_search__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(**/secrets/**)",
      "Read(./config/credentials.json)",
      "Read(**/credentials.json)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.claude/.env)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Read(~/.netrc)"
    ]
  },
  "model": "haiku",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/zulu/.claude/hooks/format-code.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"console.log(JSON.stringify({hookSpecificOutput:{hookEventName:'PreToolUse',permissionDecision:'deny',permissionDecisionReason:'⛔ Use ddg_search for web searches'}}))\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(rm *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(dd *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(mkfs *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(chmod *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(curl *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(wget *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(git push *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(git reset *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(git clean *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(git checkout *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(docker *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(sudo *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(crontab *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(printenv *)"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-commands.js",
            "if": "Bash(env)"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/protect-secrets.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash ~/.claude/hooks/statusline.sh"
  },
  "enabledPlugins": {
    "repomix-mcp@repomix": true,
    "context7@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "web-search@syed-plugins": true
  },
  "extraKnownMarketplaces": {
    "repomix": {
      "source": {
        "source": "github",
        "repo": "yamadashy/repomix"
      }
    },
    "syed-plugins": {
      "source": {
        "source": "github",
        "repo": "sydasif/claude-plugins"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipWorkflowUsageWarning": true,
  "theme": "dark"
}
