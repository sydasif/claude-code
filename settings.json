{
  "autoUpdatesChannel": "latest",
  "effortLevel": "high",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "repomix-mcp@repomix": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "sk-1234",
    "ANTHROPIC_BASE_URL": "http://localhost:8080/anthropic",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "gemma-4-26b-a4b-it",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "gemma-4-31b-it",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "gemini-3.1-flash-lite",
    "ENABLE_LSP_TOOL": "1"
  },
  "extraKnownMarketplaces": {
    "repomix": {
      "source": {
        "repo": "yamadashy/repomix",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash /home/zulu/.claude/hooks/format-after-edit.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash /home/zulu/.claude/hooks/block-websearch.sh",
            "type": "command"
          }
        ],
        "matcher": "WebSearch"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-dangerous-commands.js"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/protect-secrets.js"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": ["WebSearch"]
  },
  "statusLine": {
    "command": "/bin/bash ~/.claude/hooks/statusline.sh",
    "type": "command"
  },
  "theme": "dark"
}
