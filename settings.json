{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:4000",
    "ANTHROPIC_AUTH_TOKEN": "sk-1234",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "gemini/gemini-3.1-flash-lite",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "gemini/gemma-4-31b-it",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "gemini/gemma-4-26b-a4b-it"
  },
  "permissions": {
    "allow": [
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(git diff)",
      "Bash(git status)",
      "Bash(ruff check *)"
    ],
    "deny": [
      "Read(.git/*)",
      "Bash(mkfs *)",
      "Bash(sudo *)",
      "Read(id_rsa*)",
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Read(secrets.json)",
      "Read(credentials.json)",
      "Bash(git push --force *)"
    ]
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/zulu/.claude/hooks/audit_logger.py"
          },
          {
            "type": "command",
            "command": "python3 /home/zulu/.claude/hooks/format_python.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/zulu/.claude/hooks/block_secrets.py"
          },
          {
            "type": "command",
            "command": "python3 /home/zulu/.claude/hooks/block_pip.py"
          },
          {
            "type": "command",
            "command": "python3 /home/zulu/.claude/hooks/advise_threading.py"
          }
        ]
      }
    ],
    "Stop": []
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash ~/.claude/hooks/statusline.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "repomix-mcp@repomix": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "repomix": {
      "source": {
        "source": "github",
        "repo": "yamadashy/repomix"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "theme": "dark"
}
